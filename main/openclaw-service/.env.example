# OpenClaw Service Configuration

# Server
PORT=8003
NODE_ENV=development

# Manager API Integration
MANAGER_API_URL=http://localhost:8002/toy
MANAGER_API_SECRET=your-service-secret-key

# MQTT Gateway Integration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# LiveKit Integration
LIVEKIT_URL=wss://your-livekit-url
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# WhatsApp Integration (whatsapp-web.js)
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_PATH=./memory/whatsapp-session

# Telegram Integration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Slack Integration
SLACK_ENABLED=false
SLACK_BOT_TOKEN=your-slack-bot-token

# Task Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Kolkata

# Memory Storage
MEMORY_PATH=./memory
MEMORY_MAX_SIZE_MB=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/openclaw.log

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# AI Services (OpenClaw Agent)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Feature Flags
ENABLE_OPENCLAW_AGENT=false
ENABLE_PROACTIVE_REMINDERS=true
ENABLE_PARENT_NOTIFICATIONS=true
ENABLE_WEB_AUTOMATION=false
ENABLE_FILE_STORAGE=true
