# Dockerfile.flyio - Ultra-optimized for Fly.io (under 8GB rootfs)
# Key optimizations:
# - Uses python:3.11-slim-bookworm (smaller base)
# - CPU-only PyTorch (saves ~2GB)
# - No model downloads at build time (download to volume at runtime)
# - Aggressive cache cleanup
ARG PYTHON_VERSION=3.11
FROM python:${PYTHON_VERSION}-slim-bookworm

# Prevent Python from buffering stdout/stderr
ENV PYTHONUNBUFFERED=1
ENV PORT=8080

# Set model cache directories to volume mount
ENV TRANSFORMERS_CACHE=/data/cache
ENV HF_HOME=/data/cache
ENV SENTENCE_TRANSFORMERS_HOME=/data/models

WORKDIR /app

# Install minimal system dependencies for audio processing
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    bash \
    gcc \
    g++ \
    python3-dev \
    libasound2-dev \
    portaudio19-dev \
    libffi-dev \
    libssl-dev \
    ffmpeg \
    dos2unix \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Install CPU-only PyTorch FIRST (saves ~2GB vs CUDA version)
RUN pip install --no-cache-dir \
    torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu

# Copy and install requirements (will use already-installed CPU torch)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt && \
    rm -rf ~/.cache/pip

# Install LiveKit agents and plugins (Gemini Realtime focused)
# Using --no-deps for torch-dependent packages to avoid re-downloading
RUN pip install --no-cache-dir \
    'livekit-agents[openai,silero]~=1.2' \
    'livekit-plugins-turn-detector' \
    'livekit-plugins-google' \
    'google-genai' \
    'livekit-plugins-noise-cancellation~=0.2' \
    'livekit-plugins-groq' \
    'livekit-plugins-deepgram' \
    'livekit-plugins-elevenlabs' \
    'python-dotenv' \
    'aiohttp' \
    'pydub' \
    'edge-tts==7.0.2' \
    'gtts' \
    'pyttsx3' \
    'jinja2' \
    'pytz' \
    'uvicorn[standard]' \
    'fastapi>=0.104.0' && \
    rm -rf ~/.cache/pip

# Install sentence-transformers and qdrant (for RAG - models download at runtime)
RUN pip install --no-cache-dir \
    'sentence-transformers>=2.2.0' \
    'qdrant-client>=1.7.0' && \
    rm -rf ~/.cache/pip

# Copy the entire application
COPY . .

# Ensure start script is executable
RUN dos2unix /app/start-cloudrun.sh 2>/dev/null || true && \
    chmod +x /app/start-cloudrun.sh

# DON'T download models at build time - let them download to volume at runtime
# This keeps the image small

# Create data directory for volume mount
RUN mkdir -p /data/cache /data/models

# Expose the health check port
EXPOSE 8080

# Run the start script
CMD ["bash", "start-cloudrun.sh"]
