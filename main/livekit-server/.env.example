# ============================================================================
# TTS VOICE CLONING CONFIGURATION
# ============================================================================
# Choose your TTS provider: "elevenlabs" (best quality) or "cartesia" (fastest)
# ============================================================================

# Provider selection: elevenlabs or cartesia
TTS_PROVIDER=elevenlabs

# ============================================================================
# ELEVENLABS CONFIGURATION (Recommended for Voice Cloning)
# ============================================================================
# Best for: High-quality, emotional, expressive voices
# Latency: ~300-800ms
# Voice cloning: Upload 1-3 min audio to https://elevenlabs.io/voice-lab
# ============================================================================

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Model options:
# - eleven_turbo_v2_5: Fastest (recommended for live agents)
# - eleven_multilingual_v2: Best quality, supports 29 languages (Hindi, etc.)
# - eleven_monolingual_v1: English only, older model

# ============================================================================
# CARTESIA CONFIGURATION (Fastest Option)
# ============================================================================
# Best for: Ultra-low latency applications
# Latency: ~50-100ms
# Voice cloning: Upload 1-5 min audio to https://cartesia.ai/
# ============================================================================

CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=your_cloned_voice_id_here
CARTESIA_MODEL=sonic-2

# Model options:
# - sonic-2: Current stable (recommended)
# - sonic-3: Latest model (if available)

# ============================================================================
# HOW TO CLONE A VOICE
# ============================================================================
# 1. ElevenLabs:
#    - Go to: https://elevenlabs.io/voice-lab
#    - Click "Instant Voice Cloning"
#    - Upload 1-3 minutes of clean audio
#    - Copy the Voice ID
#    - Set ELEVENLABS_VOICE_ID=your_voice_id
#
# 2. Cartesia:
#    - Go to: https://cartesia.ai/
#    - Navigate to Voice Clone section
#    - Upload 1-5 minutes of clean audio
#    - Copy the Voice ID
#    - Set CARTESIA_VOICE_ID=your_voice_id
#
# See TTS_VOICE_CLONING_CONFIG.md for detailed instructions
# ============================================================================
