# ... existing MQTT broker, LiveKit, UDP config ...

# -------------------------------------------
# HTTP Publish Server (for Manager API / Worker)
# -------------------------------------------
# Port for the HTTP endpoint that accepts POST /publish requests
# Used by Manager API to send MQTT exhaust messages to devices
HTTP_PUBLISH_PORT=3001
# Secret key for authenticating HTTP publish requests
HTTP_PUBLISH_SECRET=your-http-publish-secret
