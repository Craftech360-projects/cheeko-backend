# mqtt-gateway environment template. Copy to .env and fill in real values.

# --- MQTT broker (EMQX) ---
EMQX_HOST=127.0.0.1
EMQX_PORT=1883
EMQX_PROTOCOL=mqtt
MQTT_SIGNATURE_KEY=your-mqtt-signature-key

# --- UDP audio plane ---
UDP_PORT=8884
PUBLIC_IP=127.0.0.1

# --- manager-api (device DB, character/profile, AI Imagine upload) ---
MANAGER_API_URL=http://127.0.0.1:8002/toy
# MUST match manager-api-node's SERVICE_SECRET_KEY (sent as X-Service-Key).
MANAGER_API_SECRET=your-service-secret-key
MQTT_GATEWAY_INTERNAL_HOST=127.0.0.1
MQTT_GATEWAY_INTERNAL_PORT=8091

# --- AI Imagine ---
# REQUIRED for AI Imagine: WebSocket URL of the line_art server (note the /ws path).
# If unset, every imagine request fails instantly ("imagine timeout"/connect error).
LINE_ART_WS_URL=ws://127.0.0.1:8090/ws
# Max time to wait for line_art to return a generated image (ms). FLUX can be slow.
IMAGINE_TIMEOUT_MS=90000

# --- media / integrations ---
MEDIA_API_BASE=http://127.0.0.1:8003
CEREBRIUM_API_TOKEN=your-cerebrium-token
MEM0_API_KEY=your-mem0-key
MEM0_API_URL=https://api.mem0.ai/v1/memories/

# --- logging / observability ---
LOG_LEVEL=info
CAPTURE_CONSOLE_LOGS=true
LOKI_HOST=
LOKI_USER=
LOKI_PASSWORD=
ANALYTICS_AUDIT_LOG_ENABLED=false
ANALYTICS_AUDIT_LOG_PATH=logs/analytics-events.ndjson
ANALYTICS_AUDIT_LOG_INCLUDE_PAYLOAD=false
