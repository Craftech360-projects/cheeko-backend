# AI Imagine local storage via MinIO (S3-compatible). Copy these into manager-api's .env
# to switch image storage from AWS S3/CloudFront to a local MinIO. Unset them for AWS.
#
# 1. Start MinIO:
#    docker run -d -p 9000:9000 -p 9001:9001 \
#      -e MINIO_ROOT_USER=minioadmin -e MINIO_ROOT_PASSWORD=minioadmin \
#      minio/minio server /data --console-address ":9001"
# 2. Create bucket + public policy:  node deploy/minio-setup.js
# 3. Set the vars below and restart manager-api.
#
# NOTE: use the MinIO host's LAN IP (not 127.0.0.1) if a real device must fetch the URL;
# the device also expects HTTPS, so plain-HTTP MinIO works for the browser/client.py test
# path but a real device needs MinIO behind TLS (or a firmware dev-flag allowing HTTP).

S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET_NAME=imagine-local
IMAGINE_PUBLIC_BASE=http://127.0.0.1:9000/imagine-local
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
