generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model ai_agent {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               BigInt?
  agent_code            String?                 @db.VarChar(100)
  agent_name            String                  @db.VarChar(200)
  asr_model_id          String?                 @db.Uuid
  vad_model_id          String?                 @db.Uuid
  llm_model_id          String?                 @db.Uuid
  vllm_model_id         String?                 @db.Uuid
  tts_model_id          String?                 @db.Uuid
  tts_voice_id          String?                 @db.Uuid
  mem_model_id          String?                 @db.Uuid
  intent_model_id       String?                 @db.Uuid
  chat_history_conf     Int?                    @default(0)
  system_prompt         String?
  summary_memory        String?
  lang_code             String?                 @default("en") @db.VarChar(10)
  language              String?                 @default("English") @db.VarChar(50)
  sort                  Int?                    @default(0)
  status                Int?                    @default(1)
  creator               BigInt?
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  sys_user              sys_user?               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ai_agent_chat_history ai_agent_chat_history[]

  @@index([user_id], map: "idx_ai_agent_user")
}

model ai_agent_chat_history {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mac_address String?   @db.VarChar(20)
  agent_id    String?   @db.Uuid
  session_id  String    @db.VarChar(100)
  chat_type   Int
  content     String?
  audio_id    String?   @db.VarChar(100)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  ai_agent    ai_agent? @relation(fields: [agent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([agent_id], map: "idx_chat_history_agent")
  @@index([session_id], map: "idx_chat_history_session")
}

model ai_agent_template {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_code        String?   @db.VarChar(100)
  agent_name        String    @db.VarChar(200)
  asr_model_id      String?   @db.Uuid
  vad_model_id      String?   @db.Uuid
  llm_model_id      String?   @db.Uuid
  vllm_model_id     String?   @db.Uuid
  tts_model_id      String?   @db.Uuid
  tts_voice_id      String?   @db.Uuid
  mem_model_id      String?   @db.Uuid
  intent_model_id   String?   @db.Uuid
  chat_history_conf Int?      @default(1)
  system_prompt     String?
  summary_memory    String?
  lang_code         String?   @default("en") @db.VarChar(10)
  language          String?   @default("English") @db.VarChar(50)
  sort              Int?      @default(0)
  is_visible        Int?      @default(1)
  creator           BigInt?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updater           BigInt?
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([agent_code])
  @@index([is_visible])
}

model ai_device {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           BigInt?
  mac_address       String    @unique @db.VarChar(20)
  last_connected_at DateTime? @db.Timestamptz(6)
  auto_update       Int?      @default(1) @db.SmallInt
  board             String?   @db.VarChar(100)
  alias             String?   @db.VarChar(255)
  agent_id          String?   @db.Uuid
  kid_id            BigInt?
  mode              String?   @default("conversation") @db.VarChar(50)
  device_mode       String?   @default("auto") @db.VarChar(50)
  app_version       String?   @db.VarChar(50)
  sort              Int?      @default(0)
  creator           BigInt?
  create_date       DateTime? @default(now()) @db.Timestamptz(6)
  updater           BigInt?
  update_date       DateTime? @default(now()) @db.Timestamptz(6)
  openclaw_url      String?
  openclaw_token    String?
  sys_user          sys_user? @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([agent_id], map: "idx_ai_device_agent")
  @@index([kid_id], map: "idx_ai_device_kid")
  @@index([mac_address], map: "idx_ai_device_mac")
  @@index([user_id], map: "idx_ai_device_user")
}

model ai_model_provider {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text")) @db.VarChar(36)
  model_type    String   @db.VarChar(50)
  provider_code String   @db.VarChar(100)
  name          String   @db.VarChar(255)
  fields        Json     @default("[]")
  sort          Int      @default(0)
  creator       BigInt?
  create_date   DateTime @default(now()) @db.Timestamptz(6)
  updater       BigInt?
  update_date   DateTime @default(now()) @db.Timestamptz(6)

  @@unique([model_type, provider_code])
  @@index([model_type])
  @@index([provider_code])
}

model ai_model_config {
  id           String         @id @default(dbgenerated("(gen_random_uuid())::text")) @db.VarChar(36)
  model_type   String         @db.VarChar(50)
  model_code   String         @db.VarChar(100)
  model_name   String         @db.VarChar(255)
  is_default   Int            @default(0) @db.SmallInt
  is_enabled   Int            @default(1) @db.SmallInt
  config_json  Json           @default("{}")
  doc_link     String?        @db.VarChar(500)
  remark       String?        @db.VarChar(500)
  sort         Int            @default(0)
  creator      BigInt?
  create_date  DateTime       @default(now()) @db.Timestamptz(6)
  updater      BigInt?
  update_date  DateTime       @default(now()) @db.Timestamptz(6)
  ai_tts_voice ai_tts_voice[]

  @@index([is_default])
  @@index([model_code])
  @@index([model_type])
}

model ai_music {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String    @db.VarChar(300)
  artist     String?   @db.VarChar(200)
  album      String?   @db.VarChar(200)
  category   String?   @db.VarChar(100)
  language   String?   @db.VarChar(50)
  duration   Int?
  file_url   String?   @db.VarChar(500)
  cover_url  String?   @db.VarChar(500)
  lyrics     String?
  sort       Int?      @default(0)
  status     Int?      @default(1)
  creator    BigInt?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model ai_ota {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firmware_name String    @db.VarChar(255)
  type          String    @db.VarChar(50)
  version       String    @db.VarChar(50)
  size          Int?
  remark        String?
  firmware_path String?   @db.VarChar(500)
  force_update  Int?      @default(0)
  creator       BigInt?
  create_date   DateTime? @default(now()) @db.Timestamptz(6)
  update_date   DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([type, version])
  @@index([type], map: "idx_ai_ota_type")
  @@index([version], map: "idx_ai_ota_version")
}

model ai_rfid_scan_log {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mac_address String?      @db.VarChar(20)
  rfid_uid    String?      @db.VarChar(50)
  tag_id      String?      @db.Uuid
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  ai_rfid_tag ai_rfid_tag? @relation(fields: [tag_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ai_rfid_tag {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uid              String             @unique @db.VarChar(50)
  name             String?            @db.VarChar(200)
  description      String?
  content_type     String?            @db.VarChar(50)
  content_id       String?            @db.Uuid
  action_type      String?            @db.VarChar(50)
  action_params    Json?
  device_mac       String?            @db.VarChar(20)
  status           Int?               @default(1)
  creator          BigInt?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  ai_rfid_scan_log ai_rfid_scan_log[]

  @@index([uid], map: "idx_rfid_uid")
}

model ai_story {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String    @db.VarChar(300)
  author     String?   @db.VarChar(200)
  category   String?   @db.VarChar(100)
  language   String?   @db.VarChar(50)
  age_group  String?   @db.VarChar(50)
  duration   Int?
  content    String?
  audio_url  String?   @db.VarChar(500)
  cover_url  String?   @db.VarChar(500)
  sort       Int?      @default(0)
  status     Int?      @default(1)
  creator    BigInt?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model ai_textbook {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title               String                @db.VarChar(300)
  subject             String?               @db.VarChar(100)
  grade               String?               @db.VarChar(50)
  language            String?               @db.VarChar(50)
  publisher           String?               @db.VarChar(200)
  cover_url           String?               @db.VarChar(500)
  description         String?
  sort                Int?                  @default(0)
  status              Int?                  @default(1)
  creator             BigInt?
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  ai_textbook_chapter ai_textbook_chapter[]
}

model ai_textbook_chapter {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  textbook_id String?      @db.Uuid
  title       String       @db.VarChar(300)
  content     String?
  audio_url   String?      @db.VarChar(500)
  sort        Int?         @default(0)
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  ai_textbook ai_textbook? @relation(fields: [textbook_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ai_tts_voice {
  id              String           @id @default(dbgenerated("(gen_random_uuid())::text")) @db.VarChar(36)
  tts_model_id    String?          @db.VarChar(36)
  sort            Int              @default(0)
  creator         BigInt?
  create_date     DateTime         @default(now()) @db.Timestamptz(6)
  languages       String?          @db.VarChar(255)
  name            String           @db.VarChar(255)
  reference_audio String?          @db.VarChar(500)
  reference_text  String?
  remark          String?          @db.VarChar(500)
  tts_voice       String?          @db.VarChar(100)
  update_date     DateTime         @default(now()) @db.Timestamptz(6)
  updater         BigInt?
  voice_demo      String?          @db.VarChar(500)
  ai_model_config ai_model_config? @relation(fields: [tts_model_id], references: [id])
}

model analytics_game_attempts {
  id               BigInt    @id @default(autoincrement())
  session_id       String    @db.VarChar(100)
  mac_address      String    @db.VarChar(50)
  game_type        String    @db.VarChar(50)
  question_text    String?
  question_type    String?   @db.VarChar(50)
  difficulty_level String?   @db.VarChar(20)
  user_answer      String?
  correct_answer   String?
  is_correct       Boolean?
  attempt_number   Int?      @default(1)
  attempt_time     DateTime? @default(now()) @db.Timestamptz(6)
  response_time_ms Int?
  answered_at      DateTime? @db.Timestamptz(6)
  metadata         Json?     @default("{}")
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([mac_address], map: "idx_analytics_attempts_mac")
  @@index([session_id], map: "idx_analytics_attempts_session")
}

model analytics_game_sessions {
  id                BigInt    @id @default(autoincrement())
  session_id        String    @unique @db.VarChar(100)
  mac_address       String    @db.VarChar(50)
  agent_id          String?   @db.Uuid
  mode_type         String    @db.VarChar(50)
  started_at        DateTime  @db.Timestamptz(6)
  ended_at          DateTime? @db.Timestamptz(6)
  duration_seconds  Int?
  interaction_count Int?      @default(0)
  completion_status String?   @default("completed") @db.VarChar(50)
  metadata          Json?     @default("{}")
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([mac_address], map: "idx_analytics_sessions_mac")
  @@index([started_at], map: "idx_analytics_sessions_started")
}

model analytics_media_playback {
  id               BigInt    @id @default(autoincrement())
  mac_address      String    @db.VarChar(50)
  content_id       BigInt?
  content_type     String    @db.VarChar(50)
  event_type       String    @db.VarChar(50)
  position_seconds Int?      @default(0)
  duration_seconds Int?
  metadata         Json?     @default("{}")
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([mac_address], map: "idx_analytics_media_mac")
}

model analytics_streaks {
  id           BigInt    @id @default(autoincrement())
  mac_address  String    @db.VarChar(50)
  streak_type  String    @db.VarChar(50)
  streak_date  DateTime  @db.Date
  streak_count Int?      @default(1)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([mac_address, streak_type, streak_date])
}

model analytics_user_progress {
  id                     BigInt    @id @default(autoincrement())
  mac_address            String    @unique @db.VarChar(50)
  kid_id                 BigInt?
  total_sessions         Int?      @default(0)
  total_duration_seconds Int?      @default(0)
  total_games_played     Int?      @default(0)
  total_correct_answers  Int?      @default(0)
  total_wrong_answers    Int?      @default(0)
  current_streak         Int?      @default(0)
  longest_streak         Int?      @default(0)
  last_activity_at       DateTime? @db.Timestamptz(6)
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  updated_at             DateTime? @default(now()) @db.Timestamptz(6)
}

model content_library {
  id               BigInt            @id @default(autoincrement())
  content_type     String            @db.VarChar(50)
  title            String            @db.VarChar(500)
  description      String?
  url              String?           @db.VarChar(1000)
  thumbnail_url    String?           @db.VarChar(500)
  duration_seconds Int?
  category         String?           @db.VarChar(100)
  tags             Json?             @default("[]")
  age_min          Int?
  age_max          Int?
  language         String?           @default("en") @db.VarChar(50)
  metadata         Json?             @default("{}")
  status           Int?              @default(1)
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  device_playlist  device_playlist[]

  @@index([category], map: "idx_content_library_category")
  @@index([content_type], map: "idx_content_library_type")
}

model device_playlist {
  id              BigInt           @id @default(autoincrement())
  device_id       BigInt?
  mac_address     String?          @db.VarChar(50)
  content_id      BigInt?
  playlist_type   String?          @default("music") @db.VarChar(50)
  position        Int?             @default(0)
  created_at      DateTime?        @default(now()) @db.Timestamptz(6)
  content_library content_library? @relation(fields: [content_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([mac_address], map: "idx_device_playlist_mac")
  @@index([playlist_type], map: "idx_device_playlist_type")
}

model device_token_usage {
  id                              BigInt    @id @default(autoincrement())
  mac_address                     String    @db.VarChar(50)
  session_id                      String?   @db.VarChar(100)
  input_tokens                    Int?      @default(0)
  output_tokens                   Int?      @default(0)
  total_tokens                    Int?      @default(0)
  input_audio_tokens              Int?      @default(0)
  input_text_tokens               Int?      @default(0)
  input_cached_tokens             Int?      @default(0)
  output_audio_tokens             Int?      @default(0)
  output_text_tokens              Int?      @default(0)
  avg_ttft_seconds                Decimal?  @default(0) @db.Decimal(10, 3)
  message_count                   Int?      @default(0)
  session_duration_seconds        Decimal?  @default(0) @db.Decimal(10, 3)
  total_response_duration_seconds Decimal?  @default(0) @db.Decimal(10, 3)
  session_count                   Int?      @default(0)
  usage_date                      DateTime  @db.Date
  created_at                      DateTime? @default(now()) @db.Timestamptz(6)
  update_date                     DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([mac_address, usage_date])
  @@index([usage_date], map: "idx_device_token_usage_date")
  @@index([mac_address], map: "idx_device_token_usage_mac")
}

model game_session {
  id               BigInt    @id @default(autoincrement())
  mac_address      String    @db.VarChar(50)
  game_type        String    @db.VarChar(50)
  session_id       String?   @db.VarChar(100)
  started_at       DateTime? @default(now()) @db.Timestamptz(6)
  ended_at         DateTime? @db.Timestamptz(6)
  duration_seconds Int?
  total_attempts   Int?      @default(0)
  correct_attempts Int?      @default(0)
  metadata         Json?     @default("{}")
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  @@index([mac_address], map: "idx_game_session_mac")
  @@index([game_type], map: "idx_game_session_type")
}

model kid_activity_log {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kid_id        BigInt?
  activity_type String       @db.VarChar(50)
  content_type  String?      @db.VarChar(50)
  content_id    String?      @db.Uuid
  duration      Int?
  metadata      Json?        @default("{}")
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  kid_profile   kid_profile? @relation(fields: [kid_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model kid_learning_progress {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kid_id      BigInt?
  subject     String       @db.VarChar(100)
  topic       String       @db.VarChar(200)
  score       Int?
  time_spent  Int?
  completed   Boolean?     @default(false)
  metadata    Json?        @default("{}")
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?    @default(now()) @db.Timestamptz(6)
  kid_profile kid_profile? @relation(fields: [kid_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([kid_id, subject, topic])
}

model kid_profile {
  id                    BigInt                  @id @default(autoincrement())
  user_id               BigInt?
  name                  String                  @db.VarChar(100)
  nickname              String?                 @db.VarChar(100)
  avatar_url            String?                 @db.VarChar(500)
  birth_date            DateTime?               @db.Date
  gender                String?                 @db.VarChar(20)
  grade                 String?                 @db.VarChar(50)
  school                String?                 @db.VarChar(200)
  interests             String[]
  language              String?                 @default("en") @db.VarChar(10)
  timezone              String?                 @db.VarChar(50)
  preferences           Json?                   @default("{}")
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  kid_activity_log      kid_activity_log[]
  kid_learning_progress kid_learning_progress[]
  sys_user              sys_user?               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_kid_profile_user")
  @@index([user_id], map: "idx_kid_profile_user_id")
}

model music_playlist {
  id         BigInt    @id @default(autoincrement())
  device_id  String    @db.Uuid
  content_id BigInt
  position   Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([device_id, content_id])
}

model parent_profile {
  id                   BigInt    @id @default(autoincrement())
  user_id              BigInt?   @unique
  email                String?   @db.VarChar(255)
  phone_number         String?   @db.VarChar(50)
  display_name         String?   @db.VarChar(255)
  avatar_url           String?   @db.VarChar(500)
  timezone             String?   @db.VarChar(50)
  language             String?   @default("en") @db.VarChar(10)
  email_notifications  Boolean?  @default(true)
  push_notifications   Boolean?  @default(true)
  weekly_report        Boolean?  @default(true)
  onboarding_completed Boolean?  @default(false)
  terms_accepted_at    DateTime? @db.Timestamptz(6)
  terms_version        String?   @db.VarChar(20)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  openclaw_url         String?
  openclaw_token       String?
  sys_user             sys_user? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model rfid_card_mapping {
  id                BigInt             @id @default(autoincrement())
  rfid_uid          String             @unique @db.VarChar(50)
  content_pack_id   BigInt?
  pack_id           BigInt?
  question_id       BigInt?
  question_pack_id  BigInt?
  question_ids      Json               @default("[]")
  pack_code         String?            @db.VarChar(100)
  action_type       String?            @db.VarChar(50)
  action_data       Json?              @default("{}")
  notes             String?            @db.VarChar(500)
  active            Boolean            @default(true)
  status            Int?               @default(1)
  creator           BigInt?
  create_date       DateTime           @default(now()) @db.Timestamptz(6)
  updater           BigInt?
  update_date       DateTime           @default(now()) @db.Timestamptz(6)
  card_type         String?            @default("content") @db.VarChar(20)
  rfid_content_pack rfid_content_pack? @relation(fields: [content_pack_id], references: [id], onUpdate: NoAction)
  rfid_pack         rfid_pack?         @relation(fields: [pack_id], references: [id], onUpdate: NoAction)
  rfid_question     rfid_question?     @relation(fields: [question_id], references: [id], onUpdate: NoAction)

  @@index([rfid_uid], map: "idx_rfid_card_mapping_uid")
  @@index([question_id], map: "idx_rfid_card_mapping_question")
  @@index([pack_id], map: "idx_rfid_card_mapping_pack_id")
  @@index([content_pack_id], map: "idx_rfid_card_mapping_pack")
  @@index([active], map: "idx_rfid_card_mapping_active")
}

