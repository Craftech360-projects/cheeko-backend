# ===========================================
# Cheeko Manager API (Node.js) - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# -------------------------------------------
# Server Configuration
# -------------------------------------------
PORT=8002
NODE_ENV=development
# Context path for all routes (matches Spring Boot)
CONTEXT_PATH=/toy

# -------------------------------------------
# Supabase Configuration (REQUIRED)
# -------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------
# Prisma Database URLs (REQUIRED for Prisma)
# -------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/database
#
# DATABASE_URL: Connection pooler URL (Transaction mode for application)
# Uses port 6543 with ?pgbouncer=true for connection pooling
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: Direct connection URL (for migrations and introspection)
# Uses port 5432 for direct PostgreSQL connection
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# -------------------------------------------
# Service-to-Service Authentication
# -------------------------------------------
# Used by LiveKit agents and other backend services
# Should match the value in your existing Spring Boot .env
SERVICE_SECRET_KEY=your-service-secret-key

# -------------------------------------------
# Qdrant Vector Database (For RFID RAG)
# -------------------------------------------
# Get these from: https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster-id.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=rfid_content

# -------------------------------------------
# Mem0 Memory API (For Agent Personalization)
# -------------------------------------------
# Get from: https://app.mem0.ai/
MEM0_API_KEY=your-mem0-api-key

# -------------------------------------------
# Optional: Logging
# -------------------------------------------
LOG_LEVEL=debug
# Options: error, warn, info, http, verbose, debug, silly

# -------------------------------------------
# Optional: Gemini Health Check Dependency
# -------------------------------------------
# Used by /toy/health/deps/gemini endpoint
# Set either GEMINI_API_KEY or GOOGLE_API_KEY
# GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY=your-google-api-key

# -------------------------------------------
# Optional: ElevenLabs Health Check Dependency
# -------------------------------------------
# Used by /toy/health/deps/elevenlabs endpoint
# Set either ELEVENLABS_API_KEY or ELEVEN_API_KEY
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVEN_API_KEY=your-elevenlabs-api-key

# -------------------------------------------
# Optional: LiveKit Default Runtime Agent
# -------------------------------------------
# Runtime agent name used when a Character has no runtime_agent_name set.
LIVEKIT_DEFAULT_AGENT=cheeko-agent1

# -------------------------------------------
# Optional: Rate Limiting
# -------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# -------------------------------------------
# JWT Configuration (if not using Supabase default)
# -------------------------------------------
# JWT_SECRET=your-jwt-secret
# JWT_EXPIRES_IN=7d
